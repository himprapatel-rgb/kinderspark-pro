# ─────────────────────────────────────────────────────────────
# KinderSpark Pro — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (required)
DATABASE_URL="postgresql://kinderspark:password@localhost:5432/kinderspark"

# Server port (optional, default 4000)
PORT=4000

NODE_ENV=development

# Anthropic API key for Claude AI features (required)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-your-key-here"

# Override Claude model (optional, default claude-sonnet-4-6)
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# JWT secret for signing tokens — use a long random string in production
# Generate one: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-secret"

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"
