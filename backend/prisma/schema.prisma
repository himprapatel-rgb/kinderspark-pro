generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id        String   @id @default(cuid())
  name      String
  classes   Class[]
  createdAt DateTime @default(now())
}

model Class {
  id         String          @id @default(cuid())
  name       String
  grade      String          @default("KG 1")
  schoolId   String?
  school     School?         @relation(fields: [schoolId], references: [id])
  students   Student[]
  homework   Homework[]
  messages   Message[]
  syllabuses  ClassSyllabus[]
  attendance  Attendance[]
  createdAt   DateTime        @default(now())
}

model Student {
  id            String               @id @default(cuid())
  name          String
  age           Int                  @default(5)
  avatar        String               @default("👧")
  pin           String
  stars         Int                  @default(0)
  streak        Int                  @default(0)
  grade         String?
  aiStars       Int                  @default(0)
  aiSessions    Int                  @default(0)
  aiBestLevel   Int                  @default(1)
  ownedItems    String[]             @default(["av_def", "th_def"])
  selectedTheme String               @default("th_def")
  lastLoginAt   DateTime?
  pushToken     String?
  classId       String
  class         Class                @relation(fields: [classId], references: [id])
  progress      Progress[]
  completions   HomeworkCompletion[]
  aiSessionLogs AISession[]
  badges        Badge[]
  feedback      Feedback?
  attendance    Attendance[]
  createdAt     DateTime             @default(now())
}

model Badge {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      String
  earnedAt  DateTime @default(now())

  @@unique([studentId, type])
}

model Syllabus {
  id          String          @id @default(cuid())
  title       String
  icon        String          @default("📖")
  color       String          @default("#5E5CE6")
  grade       String          @default("all")
  type        String          @default("custom")
  description String?
  published   Boolean         @default(false)
  assignedTo  String?
  items       SyllabusItem[]
  homework    Homework[]
  classes     ClassSyllabus[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ClassSyllabus {
  classId    String
  syllabusId String
  class      Class    @relation(fields: [classId], references: [id])
  syllabus   Syllabus @relation(fields: [syllabusId], references: [id])

  @@id([classId, syllabusId])
}

model SyllabusItem {
  id         String   @id @default(cuid())
  word       String
  emoji      String   @default("⭐")
  hint       String?
  order      Int      @default(0)
  syllabusId String
  syllabus   Syllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
}

model Homework {
  id           String               @id @default(cuid())
  title        String
  description  String?
  moduleId     String?
  syllabusId   String?
  syllabus     Syllabus?            @relation(fields: [syllabusId], references: [id])
  dueDate      String
  assignedTo   String               @default("all")
  starsReward  Int                  @default(5)
  aiGenerated  Boolean              @default(false)
  classId      String
  class        Class                @relation(fields: [classId], references: [id])
  completions  HomeworkCompletion[]
  createdAt    DateTime             @default(now())
}

model HomeworkCompletion {
  id          String   @id @default(cuid())
  homeworkId  String
  homework    Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  done        Boolean  @default(false)
  completedAt DateTime @default(now())

  @@unique([homeworkId, studentId])
}

model Progress {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  moduleId  String
  cards     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([studentId, moduleId])
}

model Message {
  id        String   @id @default(cuid())
  from      String
  fromId    String?
  to        String
  subject   String
  body      String
  read      Boolean  @default(false)
  classId   String?
  class     Class?   @relation(fields: [classId], references: [id])
  createdAt DateTime @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  studentId String   @unique
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grade     String?
  note      String?
  updatedAt DateTime @updatedAt
}

model AISession {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topic     String
  correct   Int      @default(0)
  total     Int      @default(0)
  stars     Int      @default(0)
  maxLevel  Int      @default(1)
  accuracy  Int      @default(0)
  createdAt DateTime @default(now())
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  pin       String
  schoolId  String?
  createdAt DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  pin       String
  schoolId  String?
  createdAt DateTime @default(now())
}

model Attendance {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  date      String
  present   Boolean  @default(true)
  note      String?
  class     Class    @relation(fields: [classId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([classId, studentId, date])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  role      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ── Curriculum & Lesson Cache System ────────────────────────────────────────

model CurriculumModule {
  id        String          @id @default(cuid())
  moduleId  String          @unique              // e.g. "animals", "colors"
  title     String
  icon      String
  color     String          @default("#5E5CE6")
  type      String          @default("items")    // numbers|letters|words|items
  items     Json                                 // [{w, e, hint}] — source of truth
  active    Boolean         @default(true)
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  lessons   LessonCache[]
  questions QuizQuestion[]

  @@index([active])
}

model LessonCache {
  id         String           @id @default(cuid())
  moduleId   String
  module     CurriculumModule @relation(fields: [moduleId], references: [moduleId], onDelete: Cascade)
  language   String           @default("en")
  difficulty Int              @default(1)
  items      Json                                // AI-generated [{w, e, hint}]
  hitCount   Int              @default(0)
  createdAt  DateTime         @default(now())

  @@unique([moduleId, language, difficulty])
  @@index([moduleId])
}

model QuizQuestion {
  id         String           @id @default(cuid())
  moduleId   String
  module     CurriculumModule @relation(fields: [moduleId], references: [moduleId], onDelete: Cascade)
  question   String
  options    Json                                // ["Cat","Dog","Bird","Fish"]
  correctIdx Int
  emoji      String           @default("⭐")
  difficulty Int              @default(1)
  language   String           @default("en")
  createdAt  DateTime         @default(now())

  @@index([moduleId, difficulty, language])
}

model AIResponseCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique              // hash of prompt params
  type      String                        // lesson|feedback|report|homework|syllabus
  response  String   @db.Text
  model     String
  hitCount  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([cacheKey])
  @@index([expiresAt])
  @@index([type])
}

// ── Agent Memory System ──────────────────────────────────────────────────────

model AgentMemory {
  id          String   @id @default(cuid())
  agentId     String                          // e.g. "security-auditor"
  agentName   String                          // e.g. "Security Auditor"
  agentIcon   String   @default("🤖")
  agentColor  String   @default("#5E5CE6")
  type        String                          // observation|decision|finding|action|summary
  content     String   @db.Text              // the memory content
  metadata    Json?                           // extra: { files, issues, runId, severity }
  runId       String?                         // GitHub Actions run ID
  importance  Int      @default(1)           // 1=low 2=medium 3=high 4=critical
  createdAt   DateTime @default(now())

  @@index([agentId])
  @@index([createdAt])
  @@index([importance])
}

model AgentConversation {
  id          String   @id @default(cuid())
  fromAgentId String
  fromName    String
  fromIcon    String   @default("🤖")
  fromColor   String   @default("#5E5CE6")
  toAgentId   String                          // agent id or "all" for broadcast
  toName      String   @default("All Agents")
  message     String   @db.Text
  msgType     String   @default("update")    // alert|handoff|question|update|broadcast|fix
  resolved    Boolean  @default(false)
  resolvedBy  String?
  createdAt   DateTime @default(now())

  @@index([toAgentId])
  @@index([fromAgentId])
  @@index([createdAt])
}
